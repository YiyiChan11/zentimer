{
  "$schema": "https://raw.githubusercontent.com/nickel-org/nickel.rs/master/schema.json",
  "productName": "ZenTimer",
  "version": "1.0.0",
  "identifier": "com.zentimer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5180",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ZenTimer",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "tooltip": "ZenTimer"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2025 ZenTimer",
    "category": "Productivity",
    "shortDescription": "禅意番茄钟",
    "longDescription": "ZenTimer — 一个禅意极简的番茄钟应用，帮助你专注、呼吸，然后继续。"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ4QjU1RjBGN0E3MzY4QjQKUldTMGFITjZEMSsxMkt0RFVRQzJPbjBlNGpmRnNZcUEyRWxRNFZrYlZTUGxwSFVDOTRwUlM4MkIK",
      "endpoints": [
        "https://github.com/YiyiChan11/zentimer/releases/latest/download/latest.json"
      ]
    }
  }
}
